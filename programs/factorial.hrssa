procedure factorial:
    begin(a)
        b := 5
        delete(b)
    a > 1 -> L1(a)return2

    L1(a) <-
        an := 0 ^ (a - 1)
        res := call factorial(an)

        res2 := 0 ^ (res * a)
        0 := res ^ (res2 / a)

        delete(a)
    -> return1(res2)

    return1(a)return2 <- a > 1
    end(a)