                      0                        :=            ~add 0            =:                       _t.1
                                                             -> L0             =:  ((_m.6, _this_ref), (x, list), listLength), 0

((_m, _this_ref), (x, list), listLength), _j.0 :=           L0,L1 <-                                                              
                  _m.0, _t.1                   :=         mmem.read x          =:                        _m
                     _t.2                      :=            add 0             =:                        0
                     _t.0                      :=       equal _t.1, _t.2       =:                        ()
