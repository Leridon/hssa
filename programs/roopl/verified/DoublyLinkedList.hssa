                      ()                       :=      ~equal _t.5, _t.6       =:                       _t.4
                     _m.4                      :=    ~mmem.read listLength     =:                    _m.3, _t.6
                     _m.5                      :=         ~mmem.read x         =:                    _m.4, _t.5
                                                            -> L3,L2           =: ((_m.5, _this_ref), (x, list), listLength), _t.7

 ((_m, _this_ref), (x, list), listLength), 0   :=            L2 <-                                                                
                     _t.0                      :=              id              =:                        0
                     _tmp                      :=           dup _t.0           =:                        ()
                  _m.0, cell                   :=       mmem.allocate 1        =:                        _m
                   _m.1, 0                     :=     mmem.readwrite cell      =:                    _m.0, _tmp
                      0                        :=             ~id              =:                       _t.0
                _m.2, _newRef                  :=          _Cell._new          =:                       _m.1
                   _m.3, 0                     :=     mmem.readwrite cell      =:                  _m.2, _newRef
                     _t.1                      :=              id              =:                        0
                    _tmp.0                     :=           dup _t.1           =:                        ()
                _m.4, cellCopy                 :=       mmem.allocate 1        =:                       _m.3
                   _m.5, 0                     :=   mmem.readwrite cellCopy    =:                   _m.4, _tmp.0
                      0                        :=             ~id              =:                       _t.1
               _m.6, _ref_copy                 :=        mmem.read cell        =:                       _m.5
                   _m.7, 0                     :=   mmem.readwrite cellCopy    =:                 _m.6, _ref_copy
               _m.8, _calleeRef                :=        mmem.read cell        =:                       _m.7
             _m.9, _calleeVtable               :=     mmem.read _calleeRef     =:                       _m.8
                _calleeMethod                  :=       _calleeVtable 0        =:                        ()
                    _m.10                      := _calleeMethod cell, cellCopy =:                       _m.9
