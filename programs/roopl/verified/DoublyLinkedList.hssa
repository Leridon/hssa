                      ()                       :=          ~dup _t.2           =:                      _tmp.1
                    _m.14                      :=       ~mmem.allocate 1       =:                 _m.13, cellCopy
                      0                        :=             ~id              =:                       _t.2
             _m.15, _calleeRef.0               :=        mmem.read cell        =:                      _m.14
            _m.16, _calleeVtable.0             :=    mmem.read _calleeRef.0    =:                      _m.15
               _calleeMethod.0                 :=      _calleeVtable.0 1       =:                        ()
                    _m.17                      :=   _calleeMethod.0 cell, x    =:                      _m.16
                      ()                       :=      ~_calleeVtable.0 1      =:                 _calleeMethod.0
                    _m.18                      :=   ~mmem.read _calleeRef.0    =:              _m.17, _calleeVtable.0
