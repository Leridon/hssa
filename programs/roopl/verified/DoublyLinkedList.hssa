                      1                        :=        ~add _this_ref        =:                    listLength
                     _m.4                      :=       ~mmem.read _this       =:                 _m.3, _this_ref
                                                             -> end            =:                     _m.4, 0


rel _Program._vtable _method:
(), 0  :=     begin <-               
  i    :=    dup _method    =:   ()
                -> L4       =: (), i

(), 0  :=       L4 <-                
 res   := dup _Program.main =:   ()
                -> L5       =: res, 0

res, i :=       L5 <-                
  ()   :=   ~dup _method    =:   i
               -> end       =: res, 0


rel _Program._new:
   _m, 0    :=       begin <-                          
_m.0, _anon :=   mmem.allocate 3    =:        _m
  _vtable   := dup _Program._vtable =:        ()
  _m.1, 0   := mmem.readwrite _anon =:  _m.0, _vtable
                      -> end        =: (_m.1, _anon), 0


rel main:
    (), 0      :=       begin <-                        
      _m       :=       mmem.new       =:       ()
 _m.0, _main   :=   mmem.allocate 1    =:       _m
_m.1, _mainObj :=    _Program._new     =:      _m.0
   _m.2, 0     := mmem.readwrite _main =: _m.1, _mainObj
     _m.3      := _Program.main _main  =:      _m.2
      ()       :=        ~dup 1        =:     _main
                         -> end        =:    _m.3, 0


rel mmem.read _addr:
     _m, 0       :=       begin <-                              
_m.0, _readvalue := mmem.readwrite _addr =:        _m, ()
   _readcopy     :=    dup _readvalue    =:          ()
    _m.1, ()     := mmem.readwrite _addr =:   _m.0, _readvalue
                           -> end        =: (_m.1, _readcopy), 0
