rel _Program.main _this:
       _m, 0        :=       begin <-                              
  _m.0, _this_ref   :=    mmem.read _this    :=         _m         
        bni         :=     add _this_ref     :=          1         
   _m.1, _newRef    :=       _RTM._new       :=        _m.0        
      _m.2, 0       :=  mmem.readwrite bni   :=    _m.1, _newRef   
 _m.3, _calleeRef   :=     mmem.read bni     :=        _m.2        
_m.4, _calleeVtable := mmem.read _calleeRef  :=        _m.3        
   _calleeMethod    :=    _calleeVtable 3    :=         ()         
       _m.5         :=   _calleeMethod bni   :=        _m.4        
        ()          :=   ~_calleeVtable 3    :=    _calleeMethod   
       _m.6         := ~mmem.read _calleeRef := _m.5, _calleeVtable
       _m.7         :=    ~mmem.read bni     :=  _m.6, _calleeRef  
         1          :=    ~add _this_ref     :=         bni        
       _m.8         :=   ~mmem.read _this    :=   _m.7, _this_ref  
                              -> end         :=       _m.8, 0      


