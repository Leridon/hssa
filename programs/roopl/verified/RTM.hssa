rel _RTM._vtable _method:
(), 0  :=         begin <-                   
  i    :=        dup _method        :=   ()  
          -> L0,L2,L4,L6,L8,L10,L12 := (), i 

(), 0  :=           L0 <-                    
 res   :=     dup _RTM.simulate     :=   ()  
                    -> L1           := res, 0

(), 0  :=           L2 <-                    
 res   :=    dup _RTM.moveRight     :=   ()  
                    -> L3           := res, 0

(), 0  :=           L4 <-                    
 res   :=       dup _RTM.inst       :=   ()  
                    -> L5           := res, 0

(), 0  :=           L6 <-                    
 res   :=       dup _RTM.init       :=   ()  
                    -> L7           := res, 0

(), 0  :=           L8 <-                    
 res   :=   dup _RTM.initLiterals   :=   ()  
                    -> L9           := res, 0

(), 0  :=          L10 <-                    
 res   :=     dup _RTM.initTape     :=   ()  
                   -> L11           := res, 0

(), 0  :=          L12 <-                    
 res   :=    dup _RTM.initRules     :=   ()  
                   -> L13           := res, 0

res, i := L1,L3,L5,L7,L9,L11,L13 <-          
  ()   :=       ~dup _method        :=   i   
                   -> end           := res, 0


rel _RTM._new:
   _m, 0    :=       begin <-                          
_m.0, _anon :=   mmem.allocate 16   :=        _m       
  _vtable   :=   dup _RTM._vtable   :=        ()       
  _m.1, 0   := mmem.readwrite _anon :=  _m.0, _vtable  
                      -> end        := (_m.1, _anon), 0


rel _Cell.getLeft _this, cell:
     _m, 0      :=       begin <-                         
_m.0, _this_ref :=   mmem.read _this    :=       _m       
     data       :=    add _this_ref     :=        1       
     left       :=    add _this_ref     :=        2       
     self       :=    add _this_ref     :=        3       
     right      :=    add _this_ref     :=        4       
_m.1, _leftVal  := mmem.readwrite right :=    _m.0, ()    
_m.2, _rightVal := mmem.readwrite cell  := _m.1, _leftVal 
   _m.3, ()     := mmem.readwrite right := _m.2, _rightVal
       4        :=    ~add _this_ref    :=      right     
       3        :=    ~add _this_ref    :=      self      
       2        :=    ~add _this_ref    :=      left      
       1        :=    ~add _this_ref    :=      data      
     _m.4       :=   ~mmem.read _this   := _m.3, _this_ref
                          -> end        :=     _m.4, 0    


