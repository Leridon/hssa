(), 0  :=     begin <-               
  i    :=    dup _method    :=   ()  
                -> L0       := (), i 

(), 0  :=       L0 <-                
 res   := dup _Program.main :=   ()  
                -> L1       := res, 0

res, i :=       L1 <-                
