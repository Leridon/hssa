_m.2, _rightVal := mmem.readwrite cell := _m.1, _leftVal 
   _m.3, ()     := mmem.readwrite left := _m.2, _rightVal
       4        :=   ~add _this_ref    :=      right     
       3        :=   ~add _this_ref    :=      self      
       2        :=   ~add _this_ref    :=      left      
       1        :=   ~add _this_ref    :=      data      
     _m.4       :=  ~mmem.read _this   := _m.3, _this_ref
                         -> end        :=     _m.4, 0    


