class Main
    int value
    int shift
    int modulo
    method main()
        value += 5
        shift += 13
        modulo += 7

        if value < modulo then
            local int new_value = (value + shift) % modulo

            value <=> new_value

            delocal int new_value = 5
        else skip
        fi value < modulo
        
        // value = 4
        // shift = 13
        // modulo = 7
