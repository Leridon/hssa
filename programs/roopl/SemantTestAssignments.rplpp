class X
    int x
    int[] y
    method main()
        // illegal
        x += x
        // illegal
        x += 1 - x
        // legal
        y[1] += y[2]
        // illegal
        y[1] += y[1]
        // illegal
        y[x + 1] += x
        // illegal
        x += y[x + 1]
        skip
        // bad typing
        y += 5
        y += x
        x += y
        y[5] += y
        x += nil
        // good typing
        y[1 + 3] += 5
        y[2] -= y[3]
        x -= 5