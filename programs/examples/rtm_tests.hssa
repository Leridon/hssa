import rtm

rel rtms.identity:
(), 0 := begin<-
->end := (0, 1, (1, (
         ((0, 1), 0, 0, 0),
         ()))), 0

rel rtms.increment:
(), 0 := begin<-
->end := (1, 6, (8, (
          ((1, 2), 0, -1, -1),
          ((2, 3), 1, 0, 0),
          ((3, 2), 0, 1, 1),
          ((3, 4), 0, 0, 1),
          ((3, 4), 0, -1, -1),
          ((4, 5), -1, 0, 0),
          ((5, 4), 0, 1, 0),
          ((5, 6), 0, -1, -1),
         ()))), 0


rel tms.increment:
(), 0 := begin<-
->end := (1, 5, (6, (
          ((1, 2), -1, -1, 1),
          ((2, 2), 1, 1, 1),
          ((2, 3), 0, 1, 0),
          ((3, 3), 1, 0, 0),
          ((3, 4), -1, -1, 0),
          ((4, 5), -1, -1, 1),
         ()))), 0


rel rtm.test:
(), 0 := begin<-
    inc := rtms.increment := ()
(0, 0, 1, 1, ()) :=   rtm.eval inc := (1, 1, 0, 1, ())
(0, 0, 1, 0, ()) :=   rtm.eval inc := (1, 1, 0, 0, ())
    () := ~rtms.increment := inc


-> end := (), 0
